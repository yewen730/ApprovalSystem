# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SQL Server (required for this app)
# SQLSERVER_CONNECTION_STRING="Server=...;Database=...;User Id=...;Password=...;Encrypt=true"

# JWT secret used to sign and verify login tokens (required)
# JWT_SECRET="replace-with-a-long-random-secret"

# Folder on the company server where uploaded request files (PDF/Excel/Word) are stored.
# Default (if unset): \\10.128.3.10\data\E_IVOICING\Approval System — files live under {entity}/{request_id}/ per PR.
# ATTACHMENTS_STORAGE_PATH="\\\\10.128.3.10\\data\\E_IVOICING\\Approval System"

# Max attachment size in bytes (default: 15728640 = 15MB)
# MAX_ATTACHMENT_BYTES=15728640

# Append-only audit log (UTF-8 text). Default: ./logs/approval-events.txt next to server.ts
# APPROVAL_EVENT_LOG_PATH="D:\\Flowmaster\\logs\\approval-events.txt"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
