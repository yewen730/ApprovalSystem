# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SQL Server (required for this app)
# SQLSERVER_CONNECTION_STRING="Server=...;Database=...;User Id=...;Password=...;Encrypt=true"

# Folder on the company server where uploaded request files (PDF/Excel/Word) are stored.
# Use an absolute path in production, e.g. D:\FlowmasterFiles or \\fileserver\flowmaster\attachments
# ATTACHMENTS_STORAGE_PATH="D:\\Flowmaster\\request-attachments"

# Append-only audit log (UTF-8 text). Default: ./logs/approval-events.txt next to server.ts
# APPROVAL_EVENT_LOG_PATH="D:\\Flowmaster\\logs\\approval-events.txt"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
